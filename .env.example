# =============================================
# Zirat Community - Environment Variables
# =============================================
# Copy this file to .env.local and fill in the values.
# Variables marked [REQUIRED] must be set for the app to work.
# Variables marked [OPTIONAL] have sensible defaults or enable optional features.

# === Database ===
# [REQUIRED] PostgreSQL connection string
DATABASE_URL="postgresql://user:password@localhost:5432/zirat_community"

# === Authentication ===
# [REQUIRED] Secret key for signing auth tokens (min 32 characters)
AUTH_SECRET="generate-a-random-secret-at-least-32-chars"
# [OPTIONAL] Legacy alias for AUTH_SECRET (NextAuth.js v4 compat)
NEXTAUTH_SECRET=""
# [OPTIONAL] Auth callback URL (used for payment redirects)
AUTH_URL="http://localhost:3000"
# [OPTIONAL] Legacy alias for AUTH_URL
NEXTAUTH_URL="http://localhost:3000"

# === Admin Credentials ===
# [REQUIRED] Email and password for the admin login
ADMIN_EMAIL="admin@example.com"
ADMIN_PASSWORD="change-this-secure-password"

# === App URLs ===
# [OPTIONAL] Public-facing base URL of the application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
# [OPTIONAL] Alternative base URL used in dunning emails
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# === Email (Resend) ===
# [OPTIONAL] Resend API key for sending transactional emails
RESEND_API_KEY=""
# [OPTIONAL] Sender email address
FROM_EMAIL="Your App Name <noreply@resend.dev>"

# === iCount Billing ===
# [OPTIONAL] iCount integration credentials for invoicing
ICOUNT_COMPANY_ID=""
ICOUNT_USER=""
ICOUNT_PASS=""
ICOUNT_API_KEY=""
# [OPTIONAL] Webhook secret for verifying iCount callbacks
ICOUNT_WEBHOOK_SECRET=""

# === Cloudinary (Image uploads) ===
# [OPTIONAL] Cloudinary credentials for image storage
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# === Encryption ===
# [OPTIONAL] 32-byte hex key for encrypting sensitive data
ENCRYPTION_KEY=""

# === Cron Jobs ===
# [OPTIONAL] Secret for authenticating cron job requests
CRON_SECRET=""

# === Migration ===
# [OPTIONAL] Secret for the subscription migration endpoint
MIGRATION_SECRET=""

# === WhatsApp ===
# [OPTIONAL] Path to WhatsApp session data
WHATSAPP_SESSION_PATH="./whatsapp-session"
# [OPTIONAL] Comma-separated list of admin phone numbers for WhatsApp bot
ADMIN_WHATSAPP_PHONES=""

# === Green API (WhatsApp gateway) ===
# [OPTIONAL] Green API credentials for WhatsApp messaging
GREEN_API_INSTANCE_ID=""
GREEN_API_TOKEN=""

# === AI / Anthropic ===
# [OPTIONAL] Anthropic API key for AI-powered WhatsApp conversations
ANTHROPIC_API_KEY=""
