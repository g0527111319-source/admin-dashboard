model CrmAutomationRule {
  id            String    @id @default(uuid())
  designerId    String
  designer      Designer  @relation(fields: [designerId], references: [id])

  ruleType      String    // phase_complete_notify | weekly_summary | office_hours | pending_reminder | countdown_alerts | smart_alerts | auto_report | auto_recommendation
  isEnabled     Boolean   @default(true)
  config        Json      @default("{}") // הגדרות ספציפיות לכל כלל
  // דוגמאות config:
  // phase_complete_notify: { emailTemplate: "...", includeNextPhase: true }
  // weekly_summary: { dayOfWeek: 0, hour: 9 }
  // office_hours: { days: [0,1,2,3,4], start: "10:00", end: "17:00" }
  // pending_reminder: { hoursBeforeFirst: 48, hoursBeforeSecond: 120 }
  // countdown_alerts: { daysBeforeDeadline: [7, 3, 1] }
  // smart_alerts: { trackViews: true, inactivityDays: 14 }
  // auto_report: { includeTimeline: true, includePhotos: true }
  // auto_recommendation: { minSurveyScore: 4 }

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@unique([designerId, ruleType])
  @@index([designerId])
}

