generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ==========================================
// ספקים — Suppliers
// ==========================================
model Supplier {
  id                String   @id @default(uuid())
  name              String   // שם העסק
  contactName       String   // שם איש קשר
  phone             String   // טלפון (WhatsApp)
  email             String?  // מייל
  logo              String?  // URL לוגו
  category          String   // קטגוריה
  city              String?  // עיר
  area              String?  // אזור שירות
  website           String?  // אתר אינטרנט
  description       String?  // תיאור קצר לפרופיל
  gallery           String[] // גלריית תמונות URLs

  // מנוי
  subscriptionStart DateTime?
  subscriptionEnd   DateTime?
  monthlyFee        Float?    // תשלום חודשי ₪
  paymentStatus     PaymentStatus @default(PENDING)
  lastPaymentDate   DateTime?

  // סטטיסטיקות
  postsThisMonth    Int      @default(0)
  totalPosts        Int      @default(0)
  totalDeals        Int      @default(0)
  totalDealAmount   Float    @default(0)
  averageRating     Float    @default(0)
  ratingCount       Int      @default(0)

  isActive          Boolean  @default(true)
  isHidden          Boolean  @default(false)
  notes             String?  // הערות פנימיות לתמר
  loginToken        String?  @unique

  // אימות
  passwordHash      String?  // סיסמה מוצפנת
  googleId          String?  @unique // Google OAuth ID
  resetToken        String?  @unique // טוקן לאיפוס סיסמה
  resetTokenExpiry  DateTime? // תפוגת טוקן איפוס

  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  posts             Post[]
  deals             Deal[]
  recommendations   Recommendation[]
  recommenders      SupplierRecommender[]
  reservations      SupplierReservation[]
}

// ==========================================
// מעצבות — Designers
// ==========================================
model Designer {
  id                   String   @id @default(uuid())
  fullName             String
  phone                String
  email                String?  @unique
  city                 String?
  area                 String?
  specialization       String?
  yearsExperience      Int?
  instagram            String?
  website              String?

  // סוג העסקה
  employmentType       EmploymentType @default(FREELANCE) // שכירה / עצמאית
  yearsAsIndependent   Int?     // שנות וותק כעצמאית

  // סטטוס אישור (רשימת המתנה)
  approvalStatus       ApprovalStatus @default(PENDING) // ממתינה / מאושרת / נדחתה

  joinDate             DateTime @default(now())

  totalDealsReported   Int      @default(0)
  totalDealAmount      Float    @default(0)
  lotteryEntriesTotal  Int      @default(0)
  lotteryWinsTotal     Int      @default(0)
  eventsAttended       Int      @default(0)

  isActive             Boolean  @default(true)
  notes                String?
  loginToken           String?  @unique

  // אימות
  passwordHash         String?  // סיסמה מוצפנת
  googleId             String?  @unique // Google OAuth ID
  resetToken           String?  @unique // טוקן לאיפוס סיסמה
  resetTokenExpiry     DateTime? // תפוגת טוקן איפוס

  // הסכמה לתנאי שימוש
  termsAcceptedAt      DateTime? // מתי אישר/ה את התנאים
  termsAcceptedIp      String?   // כתובת IP בזמן ההסכמה
  termsAcceptedAgent   String?   // User-Agent בזמן ההסכמה

  // Churn prediction (item 20)
  lastLoginAt          DateTime?
  lastActivityAt       DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  deals                Deal[]
  eventRegistrations   EventRegistration[]
  lotteryWins          LotteryWinner[]
  recommendations      Recommendation[]

  // CRM
  crmClients           CrmClient[]
  crmProjects          CrmProject[]
  crmSettings          DesignerCrmSettings?
  crmQuotes            CrmQuote[]
  crmContracts         CrmContract[]
  crmContractTemplates CrmContractTemplate[]
  crmSuppliers         CrmSupplier[]
  messageTemplates     CrmMessageTemplate[]
  whatsAppConfig       WhatsAppConfig?
  whatsAppMessages     WhatsAppMessage[]
  clientCrmSettings    ClientCrmSettings[]
  timeEntries          CrmTimeEntry[]
  calendarEvents       CrmCalendarEvent[]
  webhookEndpoints     CrmWebhookEndpoint[]
  googleCalendar       DesignerGoogleCalendar?

  // CRM V2 — פיצ'רים חדשים
  approvalRequests     CrmApprovalRequest[]
  onboardingTemplates  CrmOnboardingTemplate[]
  styleQuizTemplates   CrmStyleQuizTemplate[]
  activityLogs         CrmActivityLog[]
  clientRecommendations CrmClientRecommendation[]
  automationRules      CrmAutomationRule[]

  // V3 — 5 פיצ'רים חדשים
  workflowTemplates    CrmWorkflowTemplate[]
  inspirationBoards    CrmInspirationBoard[]
  budgetItems          CrmBudgetItem[]
  scheduleBlocks       CrmScheduleBlock[]
  handoffChecklists    CrmHandoffChecklist[]

  // Projects — פורטפוליו
  designerProjects     DesignerProject[]

  // Subscription / Membership
  subscription         DesignerSubscription?
}

// ==========================================
// פרסומים — Posts
// ==========================================
model Post {
  id                String     @id @default(uuid())
  supplierId        String
  supplier          Supplier   @relation(fields: [supplierId], references: [id])

  status            PostStatus @default(PENDING)
  scheduledTime     String?    // "10:30" / "13:30" / "20:30"
  scheduledDate     DateTime?
  publishedAt       DateTime?

  imageUrl          String?
  images            String[]   // עד 20 תמונות
  caption           String?

  hasLogo           Boolean    @default(false)
  hasSupplierLogo   Boolean    @default(false)
  hasDesignerCredit Boolean    @default(false)

  rejectionReason   String?
  whatsappMessageId String?
  approvedBy        String?

  // מחיקה אוטומטית — יום אחרי תאריך הפרסום
  autoDeleteAt      DateTime?

  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

// ==========================================
// עסקאות — Deals
// ==========================================
model Deal {
  id                    String    @id @default(uuid())
  designerId            String
  designer              Designer  @relation(fields: [designerId], references: [id])
  supplierId            String
  supplier              Supplier  @relation(fields: [supplierId], references: [id])

  amount                Float
  description           String?
  dealDate              DateTime?
  reportedAt            DateTime  @default(now())

  supplierConfirmed     Boolean   @default(false)
  supplierConfirmedAt   DateTime?

  rating                Int?      // 1-5
  ratingText            String?

  lotteryEligible       Boolean   @default(true)
  lotteryId             String?

  addedManuallyByAdmin  Boolean   @default(false)
  excludedFromLottery   Boolean   @default(false)
  exclusionReason       String?

  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

// ==========================================
// המלצות — Recommendations
// ==========================================
model Recommendation {
  id           String   @id @default(uuid())
  designerId   String
  designer     Designer @relation(fields: [designerId], references: [id])
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])

  rating       Int      // 1-5
  text         String?
  isAnonymous  Boolean  @default(false)
  isApproved   Boolean  @default(true)
  isHidden     Boolean  @default(false)

  createdAt    DateTime @default(now())

  @@unique([designerId, supplierId])
}

// ==========================================
// הגרלות — Lotteries
// ==========================================
model Lottery {
  id                  String        @id @default(uuid())
  month               String        // YYYY-MM
  prize               String
  prizeValue          Float?
  status              LotteryStatus @default(PREPARING)

  minDealAmount       Float?
  minDealCount        Int?

  eligibleDesigners   String[]
  manualAdditions     String[]
  manualExclusions    String[]

  numberOfWinners     Int           @default(1) // מספר זוכות (1, 2, 3...)
  drawnAt             DateTime?
  notes               String?

  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  winners             LotteryWinner[]
}

// ==========================================
// זוכי הגרלות — Lottery Winners
// ==========================================
model LotteryWinner {
  id           String   @id @default(uuid())
  lotteryId    String
  lottery      Lottery  @relation(fields: [lotteryId], references: [id])
  designerId   String
  designer     Designer @relation(fields: [designerId], references: [id])
  rank         Int      // מקום 1, 2, 3

  createdAt    DateTime @default(now())

  @@unique([lotteryId, rank])
  @@unique([lotteryId, designerId])
}

// ==========================================
// מעצבות ממליצות לספקים
// ==========================================
model SupplierRecommender {
  id           String   @id @default(uuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  name         String   // שם המעצבת הממליצה
  phone        String   // טלפון

  createdAt    DateTime @default(now())
}

// ==========================================
// קטגוריות ספקים דינמיות
// ==========================================
model SupplierCategory {
  id           String   @id @default(uuid())
  name         String   @unique  // שם הקטגוריה
  sortOrder    Int      @default(0)
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())
}

// ==========================================
// שעות פרסום — Publishing Slots
// ==========================================
model PublishingSlot {
  id           String   @id @default(uuid())
  dayOfWeek    Int      // 0=ראשון .. 6=שבת
  time         String   // "10:30", "13:30", "20:30"
  isActive     Boolean  @default(true)

  createdAt    DateTime @default(now())

  @@unique([dayOfWeek, time])
}

// ==========================================
// כרטיס ביקור דיגיטלי — Digital Business Card
// ==========================================
model BusinessCard {
  id              String   @id @default(uuid())

  // Owner — one of these will be set
  designerId      String?  @unique
  supplierId      String?  @unique

  // Dynamic personal fields (JSON array of { id, label, value, icon })
  fields          Json     @default("[]")

  // Social links (JSON array of { type, url })
  socialLinks     Json     @default("[]")

  // Gallery (up to 4 image URLs)
  galleryImages   String[]

  // Testimonials (JSON array of { id, name, text })
  testimonials    Json     @default("[]")

  // Theme & Colors
  themeId         String   @default("elegant-gold")
  customColors    Json?    // Custom color overrides

  // Optional card header
  title           String?
  subtitle        String?
  avatarUrl       String?
  logoUrl         String?

  // Fonts & Branding
  headingFontId   String?  // Google Font ID for headings
  bodyFontId      String?  // Google Font ID for body text
  headerBgImage   String?  // Background image URL for header

  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// ==========================================
// שריון ספקים בלוח שנה
// ==========================================
model SupplierReservation {
  id           String   @id @default(uuid())
  supplierId   String
  supplier     Supplier @relation(fields: [supplierId], references: [id])
  date         DateTime // תאריך השריון
  time         String   // שעה
  notes        String?  // הערות

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([supplierId, date, time])
}

// ==========================================
// אירועים — Events
// ==========================================
model Event {
  id                    String      @id @default(uuid())
  title                 String
  description           String?
  date                  DateTime
  location              String?
  isPaid                Boolean     @default(false)
  price                 Float?
  icountProductId       String?
  maxAttendees          Int?
  registrationDeadline  DateTime?
  imageUrl              String?
  status                EventStatus @default(DRAFT)

  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  registrations         EventRegistration[]
}

// ==========================================
// הרשמות לאירועים
// ==========================================
model EventRegistration {
  id                String              @id @default(uuid())
  eventId           String
  event             Event               @relation(fields: [eventId], references: [id])
  designerId        String
  designer          Designer            @relation(fields: [designerId], references: [id])

  registeredAt      DateTime            @default(now())
  paymentStatus     EventPaymentStatus  @default(FREE)
  icountInvoiceId   String?
  icountPaymentLink String?
  paidAt            DateTime?
  attended          Boolean             @default(false)

  @@unique([eventId, designerId])
}

// ==========================================
// לוג הודעות וואטסאפ
// ==========================================
model WhatsAppLog {
  id          String   @id @default(uuid())
  direction   String   // SENT / RECEIVED
  phone       String
  message     String
  messageType String?
  relatedTo   String?
  relatedId   String?
  status      String?

  createdAt   DateTime @default(now())
}

// ==========================================
// Enums
// ==========================================
enum PaymentStatus {
  PAID
  PENDING
  OVERDUE
  CANCELLED
}

enum PostStatus {
  PENDING
  APPROVED
  REJECTED
  PUBLISHED
}

enum LotteryStatus {
  PREPARING
  READY
  DRAWN
  COMPLETED
}

enum EventStatus {
  DRAFT
  OPEN
  CLOSED
  CANCELLED
}

enum EventPaymentStatus {
  PENDING
  PAID
  REFUNDED
  FREE
}

enum EmploymentType {
  SALARIED    // שכירה
  FREELANCE   // עצמאית
}

enum ApprovalStatus {
  PENDING     // ממתינה לאישור
  APPROVED    // מאושרת
  REJECTED    // נדחתה
}

// ==========================================
// CRM — ניהול לקוחות ופרויקטים
// ==========================================

enum CrmProjectType {
  RENOVATION       // שיפוץ
  CONSTRUCTION     // בנייה חדשה
  HOME_STYLING     // הום סטיילינג
  CONSULTATION     // ייעוץ
  COMMERCIAL       // מסחרי
  OTHER            // אחר
}

enum CrmProjectStatus {
  ACTIVE       // פעיל
  ON_HOLD      // בהמתנה
  COMPLETED    // הושלם
  CANCELLED    // בוטל
}

// לקוח של מעצבת
model CrmClient {
  id             String    @id @default(uuid())
  designerId     String
  designer       Designer  @relation(fields: [designerId], references: [id])

  name           String    // שם הלקוח
  phone          String?   // טלפון
  email          String?   // מייל
  address        String?   // כתובת הנכס
  notes          String?   // הערות פנימיות

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime? // מחיקה רכה

  projects           CrmProject[]
  portalTokens       ClientPortalToken[]
  whatsAppMessages   WhatsAppMessage[]    @relation("ClientWhatsAppMessages")
  clientSettings     ClientCrmSettings?
  surveys            CrmSatisfactionSurvey[]
  calendarEvents     CrmCalendarEvent[]   @relation("ClientCalendarEvents")

  // CRM V2
  approvalRequests     CrmApprovalRequest[]
  onboardingItems      CrmOnboardingItem[]
  styleQuizResponses   CrmStyleQuizResponse[]
  beforeAfterSets      CrmBeforeAfter[]
  clientUploads        CrmClientUpload[]
  activityLogs         CrmActivityLog[]     @relation("ClientActivityLogs")
  recommendations      CrmClientRecommendation[]

  @@index([designerId])
}

// פרויקט עיצוב
model CrmProject {
  id               String           @id @default(uuid())
  clientId         String
  client           CrmClient        @relation(fields: [clientId], references: [id])
  designerId       String
  designer         Designer         @relation(fields: [designerId], references: [id])

  name             String           // שם הפרויקט
  projectType      CrmProjectType   @default(RENOVATION)
  status           CrmProjectStatus @default(ACTIVE)
  estimatedBudget  Float?           // תקציב משוער
  address          String?          // כתובת הפרויקט
  notes            String?          // הערות פנימיות

  startDate        DateTime?
  endDate          DateTime?

  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  deletedAt        DateTime?

  phases              CrmProjectPhase[]
  messages            CrmProjectMessage[]
  documents           CrmProjectDocument[]
  photos              CrmProjectPhoto[]
  materialCategories  CrmMaterialCategory[]
  quotes              CrmQuote[]
  contracts           CrmContract[]
  tasks               CrmTask[]
  reminders           CrmReminder[]
  timeEntries         CrmTimeEntry[]
  moodboards          CrmMoodboard[]
  surveys             CrmSatisfactionSurvey[]
  calendarEvents      CrmCalendarEvent[]

  // CRM V2
  approvalRequests    CrmApprovalRequest[]
  onboardingItems     CrmOnboardingItem[]
  beforeAfterSets     CrmBeforeAfter[]
  clientUploads       CrmClientUpload[]
  activityLogs        CrmActivityLog[]
  projectSettings     CrmProjectSettings?

  // V3 — 5 פיצ'רים חדשים
  handoffChecklists   CrmHandoffChecklist[]
  budgetItems         CrmBudgetItem[]
  scheduleBlocks      CrmScheduleBlock[]
  inspirationBoards   CrmInspirationBoard[]

  @@index([designerId])
  @@index([clientId])
}

// שלב בפרויקט
model CrmProjectPhase {
  id            String     @id @default(uuid())
  projectId     String
  project       CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  name          String     // שם השלב
  sortOrder     Int        @default(0)
  isCurrent     Boolean    @default(false)
  isCompleted   Boolean    @default(false)
  startedAt     DateTime?
  completedAt   DateTime?
  deadline      DateTime?  // דדליין לשלב — לספירה לאחור (פיצ'ר 13)

  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  @@index([projectId])
}

// הודעה בפרויקט (בין מעצבת ללקוח)
model CrmProjectMessage {
  id           String     @id @default(uuid())
  projectId    String
  project      CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  senderType   String     // "designer" | "client"
  content      String
  isRead       Boolean    @default(false)

  createdAt    DateTime   @default(now())

  @@index([projectId])
}

// מסמך מצורף לפרויקט
model CrmProjectDocument {
  id                String     @id @default(uuid())
  projectId         String
  project           CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  fileName          String
  fileUrl           String
  fileSize          Int?       // bytes
  title             String?
  description       String?
  category          String?    // plan category: electrical, plumbing, furniture, etc.
  isVisibleToClient Boolean    @default(false)

  createdAt         DateTime   @default(now())

  @@index([projectId])
}

// תמונת התקדמות בפרויקט
model CrmProjectPhoto {
  id                String     @id @default(uuid())
  projectId         String
  project           CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  imageUrl          String
  caption           String?
  phaseName         String?    // שם השלב שבו צולם
  isVisibleToClient Boolean    @default(false)

  createdAt         DateTime   @default(now())

  @@index([projectId])
}

// הגדרות CRM למעצבת (self-service)
model DesignerCrmSettings {
  id                  String   @id @default(uuid())
  designerId          String   @unique
  designer            Designer @relation(fields: [designerId], references: [id])

  // מיתוג
  companyName         String?
  logoUrl             String?
  primaryColor        String?  @default("#2563eb")
  secondaryColor      String?  @default("#f59e0b")
  tagline             String?

  // שלבי פרויקט ברירת מחדל
  defaultPhases       Json     @default("[\"ייעוץ ראשוני\",\"תכנון ועיצוב\",\"בחירת חומרים\",\"ביצוע\",\"פיקוח\",\"מסירה\"]")

  // הודעות אוטומטיות
  welcomeMessage      String?
  completionMessage   String?

  // שעות קבלה דיגיטליות (פיצ'ר 4)
  officeHoursEnabled  Boolean  @default(false)
  officeHoursDays     Json     @default("[0,1,2,3,4]") // ימים 0=א..6=שבת
  officeHoursStart    String?  @default("10:00")
  officeHoursEnd      String?  @default("17:00")

  // הגדרות ברירת מחדל לתהליכי עבודה
  workflowDefaults    Json     @default("{\"autoWelcomeEmail\":true,\"autoPhaseNotify\":true,\"requireApprovalBeforeNext\":false,\"autoSendContract\":false,\"defaultPaymentTerms\":30,\"reminderDaysBeforeDeadline\":3,\"autoWeeklySummary\":true,\"clientPortalEnabled\":true,\"allowClientUploads\":true,\"autoOnboardingFlow\":true}")
  contractDefaults    Json     @default("{\"defaultTemplateId\":null,\"autoNumbering\":true,\"numberPrefix\":\"CTR\",\"requireDesignerSignFirst\":true,\"sendEmailOnSign\":true,\"sendEmailOnView\":true,\"expirationDays\":30}")

  // הגדרות נוספות (JSON)
  features            Json     @default("{}")
  portal              Json     @default("{}")
  notifications       Json     @default("{}")
  automations         Json     @default("{}")
  quoteDefaults       Json     @default("{}")
  calendar            Json     @default("{}")

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

// ==========================================
// CRM — חומרים ובחירות
// ==========================================

model CrmMaterialCategory {
  id          String     @id @default(uuid())
  projectId   String
  project     CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name        String
  sortOrder   Int        @default(0)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  items       CrmMaterialItem[]

  @@index([projectId])
}

model CrmMaterialItem {
  id                String              @id @default(uuid())
  categoryId        String
  category          CrmMaterialCategory @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  productName       String
  supplierName      String?
  price             Float?
  notes             String?
  imageUrl          String?
  clientApproved    Boolean             @default(false)
  clientComment     String?
  isVisibleToClient Boolean             @default(true)
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt

  history           CrmMaterialHistory[]

  @@index([categoryId])
}

model CrmMaterialHistory {
  id             String          @id @default(uuid())
  materialItemId String
  materialItem   CrmMaterialItem @relation(fields: [materialItemId], references: [id], onDelete: Cascade)
  action         String          // added | updated | removed | approved | rejected
  fieldChanged   String?
  oldValue       String?
  newValue       String?
  changedBy      String?
  createdAt      DateTime        @default(now())

  @@index([materialItemId])
}

// ==========================================
// CRM — הצעות מחיר וחוזים
// ==========================================

enum CrmQuoteStatus {
  DRAFT
  SENT
  APPROVED
  REVISION_REQUESTED
  REJECTED
  CONVERTED_TO_CONTRACT
}

enum CrmContractStatus {
  DRAFT
  SENT_FOR_SIGNATURE
  SIGNED
  CANCELLED
}

model CrmQuote {
  id               String         @id @default(uuid())
  projectId        String
  project          CrmProject     @relation(fields: [projectId], references: [id])
  designerId       String
  designer         Designer       @relation(fields: [designerId], references: [id])
  quoteNumber      String?
  title            String
  services         Json           // שורות שירותים [{name, description, quantity, unitPrice, total}]
  totalAmount      Float
  paymentTerms     String?
  validUntil       DateTime?
  status           CrmQuoteStatus @default(DRAFT)
  clientApprovedAt DateTime?
  notesInternal    String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  @@index([projectId])
  @@index([designerId])
  @@index([status])
}

// תבניות חוזה — מעצבת מגדירה פעם אחת, משתמשת בכמה חוזים
model CrmContractTemplate {
  id             String   @id @default(uuid())
  designerId     String
  designer       Designer @relation(fields: [designerId], references: [id])
  name           String                              // "חוזה עיצוב פנים", "חוזה ליווי פרויקט"
  description    String?
  isDefault      Boolean  @default(false)
  isActive       Boolean  @default(true)
  sortOrder      Int      @default(0)

  // תוכן התבנית — בלוקים (פסקאות טקסט, כותרות, מפרידים)
  contentBlocks  Json     @default("[]")
  // הגדרות שדות — שדות מילוי (מעצבת, לקוח, חתימה)
  fields         Json     @default("[]")
  // הגדרות ויזואליות
  headerHtml     String?                             // HTML לכותרת עליונה (לוגו וכו')
  footerHtml     String?                             // HTML לתחתית
  styling        Json     @default("{}")             // צבעים, פונטים, מרווחים

  contracts      CrmContract[]

  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([designerId])
}

model CrmContract {
  id                    String               @id @default(uuid())
  projectId             String
  project               CrmProject           @relation(fields: [projectId], references: [id])
  designerId            String
  designer              Designer             @relation(fields: [designerId], references: [id])
  templateId            String?
  template              CrmContractTemplate? @relation(fields: [templateId], references: [id])
  contractNumber        String?
  title                 String
  pdfUrl                String?
  totalAmount           Float
  status                CrmContractStatus    @default(DRAFT)

  // שדות שמולאו — JSON של fieldId => value
  designerFieldValues   Json                 @default("{}")
  clientFieldValues     Json                 @default("{}")

  // חתימות
  clientSignedAt        DateTime?
  designerSignedAt      DateTime?
  clientSignatureData   Json?
  designerSignatureData Json?
  signatureIp           String?
  signatureAuditLog     Json?

  // לקוח
  clientName            String?
  clientEmail           String?
  clientPhone           String?

  // קישור חתימה ללקוח (טוקן ציבורי)
  signToken             String               @unique @default(uuid())
  sentToClientAt        DateTime?
  clientViewedAt        DateTime?

  // מיילים שנשלחו
  emailsSent            Json                 @default("[]")

  notesInternal         String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt

  @@index([projectId])
  @@index([designerId])
  @@index([status])
  @@index([signToken])
}

