  id              String     @id @default(uuid())
  projectId       String
  project         CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designerId      String
  designer        Designer   @relation(fields: [designerId], references: [id])

  category        String            // "מטבח", "ריצוף", "תאורה", "נגרות", "אינסטלציה"
  description     String?
  plannedAmount   Float             @default(0)
  actualAmount    Float             @default(0)
  supplierName    String?
  quoteId         String?           // קישור להצעת מחיר
  contractId      String?           // קישור לחוזה
  status          String            @default("planned") // planned, quoted, approved, paid
  notes           String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([projectId])
  @@index([designerId])
}

// ==========================================
// V3 — פיצ'ר 3: תזמון חכם (Gantt)
// ==========================================

model CrmScheduleBlock {
  id              String     @id @default(uuid())
  projectId       String
  project         CrmProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designerId      String
  designer        Designer   @relation(fields: [designerId], references: [id])

  title           String             // "אינסטלציה", "ריצוף", "נגרות"
  startDate       DateTime?
  endDate         DateTime?
  durationDays    Int                @default(7)
  color           String?            @default("#C9A84C")

  // תלויות: JSON array של block IDs שחייבים להסתיים לפני
  dependsOn       String[]           @default([])

  supplierName    String?
  supplierPhone   String?
  status          String             @default("pending") // pending, in_progress, completed, delayed
  delayReason     String?
  notes           String?
  sortOrder       Int                @default(0)

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([projectId])
  @@index([designerId])
}

// ==========================================
// V3 — פיצ'ר 4: ספריית השראה
// ==========================================

model CrmInspirationBoard {
  id              String     @id @default(uuid())
  projectId       String?
  project         CrmProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  designerId      String
  designer        Designer   @relation(fields: [designerId], references: [id])

  name            String             // "השראה למטבח", "סגנון סקנדינבי"
  description     String?
  isSharedWithClient Boolean         @default(false)
  shareToken      String?            @unique

  items           CrmInspirationItem[]

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([projectId])
  @@index([designerId])
}

model CrmInspirationItem {
  id              String               @id @default(uuid())
  boardId         String
  board           CrmInspirationBoard  @relation(fields: [boardId], references: [id], onDelete: Cascade)

  imageUrl        String
  sourceUrl       String?              // קישור מקורי (pinterest, instagram)
  title           String?
  notes           String?

  // תיוגים
  style           String?              // "מודרני", "כפרי", "מינימליסטי"
  room            String?              // "סלון", "מטבח", "חדר שינה"
  material        String?              // "עץ", "בטון", "שיש"

  clientLiked     Boolean              @default(false) // לקוח סימן ❤️
  sortOrder       Int                  @default(0)

  createdAt       DateTime             @default(now())

  @@index([boardId])
}

// ==========================================
// V3 — פיצ'ר 5: תבניות תהליך עבודה
// ==========================================

model CrmWorkflowTemplate {
  id              String     @id @default(uuid())
  designerId      String
  designer        Designer   @relation(fields: [designerId], references: [id])

  name            String             // "פרויקט עיצוב פנים סטנדרטי"
  description     String?
  projectType     String?            @default("RENOVATION")
  isDefault       Boolean            @default(false)

  // JSON: שלבים עם deadlines יחסיים
  // [{ name: "ייעוץ", daysFromStart: 0, duration: 7, tasks: [...] }, ...]
  phases          Json               @default("[]")

  // JSON: משימות ברירת מחדל לכל שלב
  defaultTasks    Json               @default("[]")

  // JSON: הודעות אוטומטיות
  autoMessages    Json               @default("[]")

  // קישורים לתבניות
  contractTemplateId  String?
  quoteTemplateData   Json           @default("{}")
  onboardingEnabled   Boolean        @default(true)

  // JSON: הגדרות תקציב ברירת מחדל
  budgetCategories    Json           @default("[]")

  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt

  @@index([designerId])
}

// ==========================================
// פרויקטים של מעצבות — Designer Projects (Portfolio)
// ==========================================
model DesignerProject {
  id             String   @id @default(cuid())
  designerId     String
  designer       Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)
  title          String
  description    String?
  category       String   @default("apartment") // apartment, house, office, commercial, other
  styleTags      String[] @default([])
  coverImageUrl  String?
  status         String   @default("private") // public, private
  suppliers      String[] @default([]) // supplier IDs linked to this project
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  images         DesignerProjectImage[]

  @@index([designerId])
  @@index([status])
}

model DesignerProjectImage {
  id        String  @id @default(cuid())
  projectId String
  project   DesignerProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  imageUrl  String
  caption   String?
  sortOrder Int     @default(0)

  @@index([projectId])
}

// ==========================================
// בוט וואטסאפ — WhatsApp Bot (AI)
// ==========================================
model WhatsAppConversation {
  id        String   @id @default(cuid())
  phone     String   @unique
  userType  String   // designer, supplier, admin
  userId    String?
  messages  Json     @default("[]") // last 10 messages for AI context
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model WhatsAppAuditLog {
  id        String   @id @default(cuid())
  phone     String
  userType  String
  userId    String?
  direction String   // inbound, outbound
  message   String
  toolUsed  String?
  createdAt DateTime @default(now())

  @@index([phone])
  @@index([createdAt])
}

model WhatsAppScheduledTask {
  id          String   @id @default(cuid())
  createdBy   String   // phone of admin who created it
  description String
  cronExpr    String?  // e.g. "0 9 * * *"
  nextRunAt   DateTime?
  lastRunAt   DateTime?
  prompt      String   // what Claude should do
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ==========================================
// הגדרות מערכת — System Settings (key/value)
// ==========================================
model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     Json
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

// ==========================================
// מנויים — Subscriptions / Membership
// ==========================================
model SubscriptionPlan {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  price         Decimal  @default(0) @db.Decimal(10, 2)
  currency      String   @default("ILS")
  billingCycle  String   @default("monthly")
  features      Json
  description   String?
  isActive      Boolean  @default(true)
  sortOrder     Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  subscriptions DesignerSubscription[]
}

model DesignerSubscription {
  id                       String   @id @default(cuid())
  designerId               String   @unique
  designer                 Designer @relation(fields: [designerId], references: [id], onDelete: Cascade)
  planId                   String
  plan                     SubscriptionPlan @relation(fields: [planId], references: [id])
  // Status values: active, trialing, past_due, grace, paused, read_only, cancelled, expired
  status                   String   @default("active")
  startedAt                DateTime @default(now())
  trialEndsAt              DateTime?
  currentPeriodStart       DateTime @default(now())
  currentPeriodEnd         DateTime
  cancelledAt              DateTime?
  cancelReason             String?
  autoRenew                Boolean  @default(true)
  // Recurring billing - defaults to true, charged monthly until user cancels
  recurringEnabled         Boolean  @default(true)
  icountCustomerId         String?
  icountSubscriptionId     String?
  icountPaymentToken       String?  // Encrypted - saved card token for recurring
  lastPaymentAt            DateTime?
  lastPaymentAmount        Decimal? @db.Decimal(10, 2)
  // Dunning / grace period (item 3)
  failedPaymentCount       Int      @default(0)
  lastFailedPaymentAt      DateTime?
  gracePeriodEndsAt        DateTime?
  nextRetryAt              DateTime?
  // Downgrade grace: 1 month read-only access to download data (item 8)
  readOnlyUntil            DateTime?
  scheduledDowngradeAt     DateTime?
  scheduledDowngradePlanId String?
  // Pause subscription (item 9)
  pausedAt                 DateTime?
  pauseEndsAt              DateTime?
  pauseReason              String?
  // Coupon applied (item 7)
  appliedCouponId          String?
  couponDiscountPercent    Int?
  couponEndsAt             DateTime?
  // Auto-promotion
  supplierCooperationCount Int      @default(0)
  promotionCheckedAt       DateTime?
  promotionNotifiedAt      DateTime?
  // Soft delete (item 17)
  deletedAt                DateTime?
  notes                    String?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  payments                 SubscriptionPayment[]
  auditLogs                SubscriptionAuditLog[]

  @@index([status, currentPeriodEnd])
  @@index([deletedAt])
}

model SubscriptionPayment {
  id              String   @id @default(cuid())
  subscriptionId  String
  subscription    DesignerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  amount          Decimal  @db.Decimal(10, 2)
  currency        String   @default("ILS")
  status          String   // pending, succeeded, failed, refunded
  paymentMethod   String?
  icountInvoiceId String?
  icountReceiptId String?
  // Idempotency (item 2) - unique event ID from iCount webhook
  icountEventId   String?  @unique
  attemptNumber   Int      @default(1)
  failureReason   String?
  paidAt          DateTime?
  createdAt       DateTime @default(now())

  @@index([subscriptionId, createdAt])
}

model SubscriptionRule {
  id               String   @id @default(cuid())
  name             String
  minSupplierCount Int      @default(0)
  timeWindowDays   Int      @default(30)
  targetPlanId     String?
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

// --- Subscription audit log (item 4) ---
model SubscriptionAuditLog {
  id             String   @id @default(cuid())
  subscriptionId String
  subscription   DesignerSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  designerId     String
  action         String   // created, plan_changed, status_changed, cancelled, paused, resumed, payment_succeeded, payment_failed, trial_granted, coupon_applied, downgraded, promoted
  actorType      String   // designer, admin, system, webhook
  actorId        String?
  actorName      String?
  fromValue      String?
  toValue        String?
  metadata       Json?
  reason         String?
  ipAddress      String?
  createdAt      DateTime @default(now())

  @@index([subscriptionId, createdAt])
  @@index([designerId, createdAt])
}

// --- Coupons (item 7) ---
model Coupon {
  id               String   @id @default(cuid())
  code             String   @unique
  description      String?
  discountType     String   @default("percent") // percent, fixed, free_months
  discountValue    Decimal  @db.Decimal(10, 2)
  durationMonths   Int      @default(1) // how many billing cycles the discount applies
  maxRedemptions   Int?
  redemptionCount  Int      @default(0)
  validFrom        DateTime @default(now())
  validUntil       DateTime?
  applicablePlanIds String[] // empty = all plans
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  redemptions      CouponRedemption[]

  @@index([code, isActive])
}

model CouponRedemption {
  id         String   @id @default(cuid())
  couponId   String
  coupon     Coupon   @relation(fields: [couponId], references: [id], onDelete: Cascade)
  designerId String
  redeemedAt DateTime @default(now())

  @@unique([couponId, designerId])
}

// --- In-app notifications (item 13) ---
model InAppNotification {
  id         String   @id @default(cuid())
  userId     String   // designer ID or admin user ID
  userType   String   @default("designer") // designer, admin
  type       String   // trial_ending, renewal_reminder, payment_failed, payment_success, subscription_cancelled, feature_locked, promotion_near, promotion_granted, pause_ending, downgrade_reminder
  title      String
  body       String
  linkUrl    String?
  icon       String?
  readAt     DateTime?
  createdAt  DateTime @default(now())

  @@index([userId, userType, readAt])
  @@index([userId, createdAt])
}

// --- Admin 2FA (item 18) ---
model AdminTwoFactorCode {
  id         String   @id @default(cuid())
  adminEmail String
  code       String   // hashed
  purpose    String   // subscription_edit, plan_delete, bulk_action
  contextId  String?  // e.g. subscription ID being edited
  expiresAt  DateTime
  usedAt     DateTime?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([adminEmail, purpose])
  @@index([expiresAt])
}

// --- Rate limit tracking (item 15) ---
model RateLimitEntry {
  id        String   @id @default(cuid())
  key       String   // e.g. "webhook:icount:<ip>" or "designer:sub:<id>"
  count     Int      @default(1)
  windowStart DateTime @default(now())
  expiresAt DateTime

  @@unique([key])
  @@index([expiresAt])
}
