  client      CrmClient?  @relation("ClientActivityLogs", fields: [clientId], references: [id])

  action      String      // phase_completed | approval_sent | client_viewed | client_approved | message_sent | photo_uploaded | quote_sent | project_created | client_uploaded | etc.
  entityType  String?     // "phase" | "approval" | "message" | "quote" | "photo" etc.
  entityId    String?     // ID של הישות הקשורה
  metadata    Json?       // נתונים נוספים גמישים
  actorType   String      @default("designer") // "designer" | "client" | "system"

  createdAt   DateTime    @default(now())

