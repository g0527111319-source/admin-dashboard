enum CrmApprovalStatus {
  PENDING_CLIENT   // ממתין ללקוח
  APPROVED         // אושר
  CHANGES_REQUESTED // הלקוח ביקש שינויים
  REJECTED         // נדחה
}

enum CrmApprovalType {
  SINGLE           // אישור פריט בודד (פיצ'ר 5, 8)
  SELECTION        // בחירה מרובה A/B/C (פיצ'ר 6)
}

model CrmApprovalRequest {
  id              String              @id @default(uuid())
  projectId       String
  project         CrmProject          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  clientId        String
  client          CrmClient           @relation(fields: [clientId], references: [id])
  designerId      String
  designer        Designer            @relation(fields: [designerId], references: [id])

  type            CrmApprovalType     @default(SINGLE)
  title           String              // "אישור הדמיית סלון" / "בחירת ריצוף"
  description     String?             // הסבר קצר
  status          CrmApprovalStatus   @default(PENDING_CLIENT)
  clientComment   String?             // הערת הלקוח
  token           String              @unique @default(uuid()) // לינק אישור מהיר (פיצ'ר 8)

  respondedAt     DateTime?
  reminderSentAt  DateTime?           // תזכורת אוטומטית (פיצ'ר 12)
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  options         CrmApprovalOption[]

  @@index([projectId])
  @@index([clientId])
  @@index([designerId])
  @@index([status])
}

model CrmApprovalOption {
  id              String              @id @default(uuid())
  approvalId      String
  approval        CrmApprovalRequest  @relation(fields: [approvalId], references: [id], onDelete: Cascade)

  label           String              // "אפשרות A" / "ריצוף פורצלן"
  description     String?
  imageUrl        String?             // תמונת האפשרות
  sortOrder       Int                 @default(0)
  isSelected      Boolean             @default(false) // הלקוח בחר באפשרות זו

  createdAt       DateTime            @default(now())

  @@index([approvalId])
}

// ==========================================
// CRM V2 — ציר זמן ולוג פעילות (פיצ'ר 9, 14)
